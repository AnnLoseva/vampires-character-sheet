{
  "rewrites": [
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(rules|rules_eng)\\.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(main|creation-wizard|i18n-dictionary|i18n-runtime|supabase|vtm-health|vtm-humanity)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
